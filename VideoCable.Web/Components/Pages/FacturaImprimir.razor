@page "/factura-imprimir/{FacturaId:int}"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using VideoCable.Domain.Entities
@using VideoCable.Domain.Enums
@using VideoCable.Infrastructure.Data

@inject AppDbContext DbContext
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>Factura</PageTitle>

@if (cargando)
{
    <p>Cargando factura...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger m-4">
        @error
    </div>
}
else if (factura is not null)
{
    <div class="acciones no-print">
        <button class="btn btn-outline-secondary" @onclick="Volver">
            Volver
        </button>

        <button class="btn btn-primary" @onclick="Imprimir">
            Imprimir / Guardar PDF
        </button>
    </div>

    <div class="factura">
        <div class="factura-header">
            <div>
                <img src="images/logo.jpg" class="logo" />
            </div>

            <div class="empresa">
                <h2>@factura.EmpresaRazonSocialSnapshot</h2>
                <div>CUIT: @factura.EmpresaCuitSnapshot</div>
                <div>Condición IVA: @factura.EmpresaCondicionIvaSnapshot</div>
                <div>Dirección: @factura.EmpresaDireccionSnapshot</div>
            </div>

            <div class="comprobante">
                <div class="tipo-box">@GetLetraComprobante()</div>
                <h3>@GetTituloComprobante()</h3>

                @if (!string.IsNullOrWhiteSpace(factura.NumeroComprobanteFormateado))
                {
                    <div>N° @factura.NumeroComprobanteFormateado</div>
                }
                else
                {
                    <div>N° Interno @factura.Id.ToString("00000000")</div>
                }

                <div>Fecha: @factura.FechaEmision.ToString("dd/MM/yyyy")</div>
            </div>
        </div>

        <hr />

        @if (factura.TipoComprobante != TipoComprobante.FacturaX &&
             factura.EstadoFiscal != EstadoFiscalFactura.Autorizada)
        {
            <div class="alert alert-warning no-print">
                Esta factura todavía no está autorizada por ARCA. No debería imprimirse como comprobante fiscal.
            </div>
        }

        <div class="cliente-box">
            <div><strong>Cliente:</strong> @factura.ClienteNombreSnapshot</div>

            @if (!string.IsNullOrWhiteSpace(factura.ClienteDireccionSnapshot))
            {
                <div><strong>Dirección:</strong> @factura.ClienteDireccionSnapshot</div>
            }

            @if (!string.IsNullOrWhiteSpace(factura.ClienteCuitSnapshot))
            {
                <div><strong>CUIT:</strong> @factura.ClienteCuitSnapshot</div>
            }
            else if (!string.IsNullOrWhiteSpace(factura.ClienteDocumentoSnapshot))
            {
                <div><strong>Documento:</strong> @factura.ClienteDocumentoSnapshot</div>
            }

            <div><strong>Condición IVA:</strong> @factura.ClienteCondicionIvaSnapshot</div>
            <div><strong>Período:</strong> @factura.PeriodoMes.ToString("00")/@factura.PeriodoAnio</div>
            <div><strong>Vencimiento:</strong> @factura.FechaVencimiento.ToString("dd/MM/yyyy")</div>
        </div>

        <table class="table table-bordered mt-4">
            <thead>
                <tr>
                    <th>Descripción</th>
                    <th class="text-end">Cantidad</th>
                    <th class="text-end">Precio unitario</th>
                    <th class="text-end">Subtotal</th>
                    <th class="text-end">IVA</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in factura.Items)
                {
                    <tr>
                        <td>@item.Descripcion</td>
                        <td class="text-end">@item.Cantidad.ToString("N2")</td>
                        <td class="text-end">@item.PrecioUnitario.ToString("C2")</td>
                        <td class="text-end">@item.Subtotal.ToString("C2")</td>
                        <td class="text-end">@item.ImporteIva.ToString("C2")</td>
                        <td class="text-end">@item.Total.ToString("C2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-end">Subtotal</th>
                    <th class="text-end">@factura.Subtotal.ToString("C2")</th>
                    <th class="text-end">@factura.ImporteIva.ToString("C2")</th>
                    <th class="text-end">@factura.Total.ToString("C2")</th>
                </tr>
            </tfoot>
        </table>

        @if (!string.IsNullOrWhiteSpace(factura.Observaciones))
        {
            <div class="mt-3">
                <strong>Observaciones:</strong> @factura.Observaciones
            </div>
        }

        @if (factura.TipoComprobante != TipoComprobante.FacturaX)
        {
            <div class="cae-box mt-4">
                @if (facturaElectronica is not null && factura.EstadoFiscal == EstadoFiscalFactura.Autorizada)
                {
                    <div><strong>CAE:</strong> @facturaElectronica.CAE</div>
                    <div><strong>Vencimiento CAE:</strong> @facturaElectronica.FechaVencimientoCAE.ToString("dd/MM/yyyy")</div>
                }
                else
                {
                    <div><strong>CAE:</strong> Pendiente de autorización</div>
                }
            </div>
        }
        else
        {
            <div class="footer">
                Comprobante interno no fiscal.
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public int FacturaId { get; set; }

    private bool cargando = true;
    private string? error;

    private Factura? factura;
    private FacturaElectronica? facturaElectronica;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            factura = await DbContext.Facturas
                .AsNoTracking()
                .Include(x => x.Items)
                .FirstOrDefaultAsync(x => x.Id == FacturaId);

            if (factura is null)
            {
                error = "No se encontró la factura solicitada.";
                return;
            }

            facturaElectronica = await DbContext.FacturasElectronicas
                .AsNoTracking()
                .FirstOrDefaultAsync(x => x.FacturaId == factura.Id);
        }
        catch (Exception ex)
        {
            error = $"Error al cargar factura: {ex.Message}";
            Console.WriteLine(ex.ToString());
        }

        cargando = false;
    }

    private async Task Imprimir()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }

    private string GetLetraComprobante()
    {
        return factura?.TipoComprobante switch
        {
            TipoComprobante.FacturaA => "A",
            TipoComprobante.FacturaB => "B",
            TipoComprobante.FacturaC => "C",
            _ => "X"
        };
    }

    private string GetTituloComprobante()
    {
        return factura?.TipoComprobante switch
        {
            TipoComprobante.FacturaA => "Factura A",
            TipoComprobante.FacturaB => "Factura B",
            TipoComprobante.FacturaC => "Factura C",
            _ => "Factura X"
        };
    }

    private void Volver()
    {
        Navigation.NavigateTo("/facturacion-mensual");
    }
}

<style>
    body {
        background: #f3f4f6;
    }

    .acciones {
        max-width: 920px;
        margin: 1rem auto;
        display: flex;
        justify-content: flex-end;
    }

    .factura {
        max-width: 920px;
        margin: 1rem auto;
        background: #ffffff;
        padding: 2rem;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        box-shadow: 0 1px 4px rgba(15, 23, 42, 0.12);
    }

    .factura-header {
        display: grid;
        grid-template-columns: 160px 1fr 240px;
        gap: 1rem;
        align-items: center;
    }

    .logo {
        max-width: 145px;
        max-height: 90px;
        object-fit: contain;
    }

    .empresa h2 {
        margin: 0 0 0.35rem 0;
        font-size: 1.35rem;
        font-weight: 800;
    }

    .comprobante {
        text-align: right;
    }

    .tipo-box {
        width: 52px;
        height: 52px;
        border: 2px solid #111827;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }

    .cliente-box {
        border: 1px solid #e5e7eb;
        background: #f9fafb;
        border-radius: 0.5rem;
        padding: 1rem;
    }

    .cae-box {
        border: 1px solid #111827;
        border-radius: 0.5rem;
        padding: 1rem;
        max-width: 360px;
        margin-left: auto;
    }

    .footer {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid #e5e7eb;
        color: #6b7280;
        font-size: 0.9rem;
    }

    @@media print {
        .no-print,
        .sidebar,
        .top-row,
        .acciones {
            display: none !important;
        }

        body {
            background: #ffffff !important;
        }

        .factura {
            max-width: 100%;
            margin: 0;
            padding: 0;
            border: none;
            box-shadow: none;
        }

        .table {
            font-size: 0.9rem;
        }
    }
</style>