@page "/suscripciones"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using VideoCable.Domain.Entities
@using VideoCable.Domain.Enums
@using VideoCable.Infrastructure.Data

@inject AppDbContext DbContext

<PageTitle>Suscripciones</PageTitle>

<div class="page-header">
    <div>
        <h1>Suscripciones</h1>
        <p class="text-muted mb-0">Servicios activos contratados por cada cliente.</p>
    </div>

    <button class="btn btn-primary" @onclick="NuevaSuscripcion">
        Nueva suscripción
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-success mt-3">@mensaje</div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3">@error</div>
}

@if (erroresValidacion.Any())
{
    <div class="alert alert-warning mt-3">
        <ul class="mb-0">
            @foreach (var item in erroresValidacion)
            {
                <li>@item</li>
            }
        </ul>
    </div>
}

@if (editando)
{
    <div class="card mt-4">
        <div class="card-header">
            @(suscripcionEditando.Id == 0 ? "Nueva suscripción" : "Editar suscripción")
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Buscar cliente</label>
                    <input class="form-control mb-2"
                           placeholder="Nombre, código, DNI o CUIT..."
                           value="@busquedaCliente"
                           @oninput="FiltrarClientes" />

                    <select class="form-select" @bind="suscripcionEditando.ClienteId">
                        <option value="0">Seleccionar cliente...</option>
                        @foreach (var cliente in clientesFiltrados)
                        {
                            <option value="@cliente.Id">@cliente.Codigo - @cliente.Nombre</option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Servicio mensual</label>
                    <select class="form-select" value="@suscripcionEditando.ServicioPlanId" @onchange="OnServicioChanged">
                        <option value="0">Seleccionar servicio...</option>
                        @foreach (var servicio in serviciosCombo)
                        {
                            <option value="@servicio.Id">
                                @servicio.Descripcion - @servicio.PrecioActual.ToString("C0")
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Buscar caja</label>
                    <input class="form-control mb-2"
                           placeholder="Código, caja o dirección..."
                           value="@busquedaCaja"
                           @oninput="FiltrarCajas" />

                    <select class="form-select" @bind="suscripcionEditando.CajaDistribucionId">
                        <option value="0">Seleccionar caja...</option>
                        @foreach (var caja in cajasFiltradas)
                        {
                            <option value="@caja.Id">@caja.Codigo - @caja.Descripcion</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Fecha alta</label>
                    <InputDate class="form-control" @bind-Value="suscripcionEditando.FechaAlta" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Estado</label>
                    <select class="form-select" @bind="suscripcionEditando.EstadoActual">
                        @foreach (var estado in Enum.GetValues<EstadoSuscripcionTipo>())
                        {
                            <option value="@estado">@estado</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Precio actual</label>
                    <InputNumber class="form-control" @bind-Value="suscripcionEditando.PrecioActualSnapshot" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Fecha baja</label>
                    <InputDate class="form-control" @bind-Value="suscripcionEditando.FechaBaja" />
                </div>

                <div class="col-md-6">
                    <label class="form-label">Dirección de instalación</label>
                    <input class="form-control"
                           placeholder="Ej: San Martín 123"
                           @bind="suscripcionEditando.DireccionInstalacion" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Localidad instalación</label>
                    <input class="form-control"
                           placeholder="Ej: Pampa del Indio"
                           @bind="suscripcionEditando.LocalidadInstalacion" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Referencia instalación</label>
                    <input class="form-control"
                           placeholder="Ej: Casa al fondo, portón negro"
                           @bind="suscripcionEditando.ReferenciaInstalacion" />
                </div>

                <div class="col-md-12">
                    <label class="form-label">Observaciones</label>
                    <input class="form-control" @bind="suscripcionEditando.Observaciones" />
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-success" @onclick="GuardarSuscripcion">
                    Guardar
                </button>

                <button class="btn btn-outline-secondary" @onclick="CancelarEdicion">
                    Cancelar
                </button>
            </div>
        </div>
    </div>
}

@if (suscripciones is null)
{
    <p class="mt-4">Cargando suscripciones...</p>
}
else
{
    <div class="card mt-4">
        <div class="card-header">
            Suscripciones registradas
        </div>

        <div class="table-responsive grid-scroll">
            <table class="table table-striped table-hover mb-0">
                <tr>
                    <th>Cliente</th>
                    <th>Servicio</th>
                    <th>Dirección instalación</th>
                    <th>Caja</th>
                    <th>Fecha alta</th>
                    <th>Estado</th>
                    <th class="text-end">Precio</th>
                    <th class="text-end">Acciones</th>
                </tr>
                <tbody>
                    @foreach (var item in suscripciones)
                    {
                        <tr>
                            <td>@item.Cliente.Codigo - @item.Cliente.Nombre</td>
                            <td>@item.ServicioPlan.Descripcion</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.DireccionInstalacion))
                                {
                                    <div>@item.DireccionInstalacion</div>

                                    @if (!string.IsNullOrWhiteSpace(item.LocalidadInstalacion))
                                    {
                                        <div class="text-muted small">@item.LocalidadInstalacion</div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(item.ReferenciaInstalacion))
                                    {
                                        <div class="text-muted small">@item.ReferenciaInstalacion</div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Sin dirección</span>
                                }
                            </td>
                            <td>@item.CajaDistribucion.Codigo - @item.CajaDistribucion.Descripcion</td>
                            <td>@item.FechaAlta.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.EstadoActual == EstadoSuscripcionTipo.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else if (item.EstadoActual == EstadoSuscripcionTipo.Suspendido)
                                {
                                    <span class="badge bg-warning text-dark">Suspendido</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Baja</span>
                                }
                            </td>
                            <td class="text-end">@item.PrecioActualSnapshot.ToString("C0")</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditarSuscripcion(item.Id)">
                                    Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Suscripcion>? suscripciones;
    private List<Cliente> clientesCombo = new();
    private List<ServicioPlan> serviciosCombo = new();
    private List<CajaDistribucion> cajasCombo = new();

    private Suscripcion suscripcionEditando = new();
    private bool editando;
    private string? mensaje;
    private string? error;
    private List<string> erroresValidacion = new();

    private List<Cliente> clientesFiltrados = new();
    private List<CajaDistribucion> cajasFiltradas = new();

    private string? busquedaCliente;
    private string? busquedaCaja;

    protected override async Task OnInitializedAsync()
    {
        await CargarCombos();
        await CargarSuscripciones();
    }

    private async Task CargarCombos()
    {
        clientesCombo = await DbContext.Clientes
            .AsNoTracking()
            .Where(x => x.Activo)
            .OrderBy(x => x.Nombre)
            .ToListAsync();

        clientesFiltrados = clientesCombo
            .Take(50)
            .ToList();

        serviciosCombo = await DbContext.ServiciosPlan
            .AsNoTracking()
            .Where(x => x.Activo && x.TipoCobro == TipoCobroServicio.Mensual)
            .OrderBy(x => x.Descripcion)
            .ToListAsync();

        cajasCombo = await DbContext.CajasDistribucion
            .AsNoTracking()
            .Where(x => x.Activa)
            .OrderBy(x => x.Codigo)
            .ToListAsync();

        cajasFiltradas = cajasCombo
            .Take(50)
            .ToList();
    }

    private void FiltrarClientes(ChangeEventArgs e)
    {
        busquedaCliente = e.Value?.ToString();

        if (string.IsNullOrWhiteSpace(busquedaCliente))
        {
            clientesFiltrados = clientesCombo
                .Take(50)
                .ToList();

            return;
        }

        var texto = busquedaCliente.Trim();

        if (texto.Length < 3)
            return;

        clientesFiltrados = clientesCombo
            .Where(x =>
                x.Nombre.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                x.Codigo.ToString().Contains(texto) ||
                (x.NumeroDocumento != null && x.NumeroDocumento.Contains(texto)) ||
                (x.Cuit != null && x.Cuit.Contains(texto)))
            .Take(50)
            .ToList();
    }

    private void FiltrarCajas(ChangeEventArgs e)
    {
        busquedaCaja = e.Value?.ToString();

        if (string.IsNullOrWhiteSpace(busquedaCaja))
        {
            cajasFiltradas = cajasCombo
                .Take(50)
                .ToList();

            return;
        }

        var texto = busquedaCaja.Trim();

        if (texto.Length < 2)
            return;

        cajasFiltradas = cajasCombo
            .Where(x =>
                x.Codigo != null && x.Codigo.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                x.Descripcion.Contains(texto, StringComparison.OrdinalIgnoreCase) ||
                x.Direccion != null && x.Direccion.Contains(texto, StringComparison.OrdinalIgnoreCase))
            .Take(50)
            .ToList();
    }

    private async Task CargarSuscripciones()
    {
        suscripciones = await DbContext.Suscripciones
            .AsNoTracking()
            .Include(x => x.Cliente)
            .Include(x => x.ServicioPlan)
            .Include(x => x.CajaDistribucion)
            .OrderBy(x => x.Cliente.Nombre)
            .Take(300)
            .ToListAsync();
    }

    private void NuevaSuscripcion()
    {
        mensaje = null;
        error = null;
        erroresValidacion.Clear();

        suscripcionEditando = new Suscripcion
        {
            ClienteId = 0,
            ServicioPlanId = 0,
            CajaDistribucionId = 0,
            EstadoActual = EstadoSuscripcionTipo.Activo,
            FechaAlta = DateTime.Today,
            PrecioActualSnapshot = 0,
            DireccionInstalacion = null,
            LocalidadInstalacion = null,
            ReferenciaInstalacion = null,
            CreatedAt = DateTime.Now
        };

        editando = true;
    }

    private async Task EditarSuscripcion(int id)
    {
        mensaje = null;
        error = null;
        erroresValidacion.Clear();

        var suscripcion = await DbContext.Suscripciones
            .AsNoTracking()
            .FirstAsync(x => x.Id == id);

        suscripcionEditando = new Suscripcion
        {
            Id = suscripcion.Id,
            ClienteId = suscripcion.ClienteId,
            ServicioPlanId = suscripcion.ServicioPlanId,
            CajaDistribucionId = suscripcion.CajaDistribucionId,
            EstadoActual = suscripcion.EstadoActual,
            FechaAlta = suscripcion.FechaAlta,
            FechaBaja = suscripcion.FechaBaja,
            PrecioActualSnapshot = suscripcion.PrecioActualSnapshot,
            DireccionInstalacion = suscripcion.DireccionInstalacion,
            LocalidadInstalacion = suscripcion.LocalidadInstalacion,
            ReferenciaInstalacion = suscripcion.ReferenciaInstalacion,
            Observaciones = suscripcion.Observaciones,
            CreatedAt = suscripcion.CreatedAt,
            CreatedByUserId = suscripcion.CreatedByUserId,
            IsDeleted = suscripcion.IsDeleted,
            RowVersion = suscripcion.RowVersion
        };

        var clienteSeleccionado = clientesCombo.FirstOrDefault(x => x.Id == suscripcion.ClienteId);
        if (clienteSeleccionado is not null && !clientesFiltrados.Any(x => x.Id == clienteSeleccionado.Id))
            clientesFiltrados.Insert(0, clienteSeleccionado);

        var cajaSeleccionada = cajasCombo.FirstOrDefault(x => x.Id == suscripcion.CajaDistribucionId);
        if (cajaSeleccionada is not null && !cajasFiltradas.Any(x => x.Id == cajaSeleccionada.Id))
            cajasFiltradas.Insert(0, cajaSeleccionada);

        editando = true;
    }

    private async Task OnServicioChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var servicioId))
        {
            suscripcionEditando.ServicioPlanId = servicioId;

            var servicio = serviciosCombo.FirstOrDefault(x => x.Id == servicioId);

            if (servicio is not null)
                suscripcionEditando.PrecioActualSnapshot = servicio.PrecioActual;
            else
                suscripcionEditando.PrecioActualSnapshot = 0;
        }

        await Task.CompletedTask;
    }

    private async Task GuardarSuscripcion()
    {
        mensaje = null;
        error = null;
        erroresValidacion.Clear();

        await ValidarSuscripcion();

        if (erroresValidacion.Any())
            return;

        try
        {
            if (suscripcionEditando.Id > 0)
            {
                var suscripcion = await DbContext.Suscripciones
                    .FirstAsync(x => x.Id == suscripcionEditando.Id);

                var estadoAnterior = suscripcion.EstadoActual;

                suscripcion.ClienteId = suscripcionEditando.ClienteId;
                suscripcion.ServicioPlanId = suscripcionEditando.ServicioPlanId;
                suscripcion.CajaDistribucionId = suscripcionEditando.CajaDistribucionId;
                suscripcion.EstadoActual = suscripcionEditando.EstadoActual;
                suscripcion.FechaAlta = suscripcionEditando.FechaAlta;
                suscripcion.FechaBaja = suscripcionEditando.FechaBaja;
                suscripcion.PrecioActualSnapshot = suscripcionEditando.PrecioActualSnapshot;
                suscripcion.DireccionInstalacion = suscripcionEditando.DireccionInstalacion;
                suscripcion.LocalidadInstalacion = suscripcionEditando.LocalidadInstalacion;
                suscripcion.ReferenciaInstalacion = suscripcionEditando.ReferenciaInstalacion;
                suscripcion.Observaciones = suscripcionEditando.Observaciones;
                suscripcion.UpdatedAt = DateTime.Now;

                if (estadoAnterior != suscripcionEditando.EstadoActual)
                {
                    DbContext.SuscripcionEstadosHistorial.Add(new SuscripcionEstadoHistorial
                    {
                        SuscripcionId = suscripcion.Id,
                        Estado = suscripcionEditando.EstadoActual,
                        Fecha = DateTime.Now,
                        Observaciones = "Cambio de estado manual"
                    });
                }
            }
            else
            {
                suscripcionEditando.CreatedAt = DateTime.Now;
                DbContext.Suscripciones.Add(suscripcionEditando);

                DbContext.SuscripcionEstadosHistorial.Add(new SuscripcionEstadoHistorial
                {
                    Suscripcion = suscripcionEditando,
                    Estado = suscripcionEditando.EstadoActual,
                    Fecha = DateTime.Now,
                    Observaciones = "Alta inicial de suscripción"
                });
            }

            await DbContext.SaveChangesAsync();

            editando = false;
            mensaje = "Suscripción guardada correctamente.";

            await CargarSuscripciones();
        }
        catch (DbUpdateException ex)
        {
            error = "No se pudo guardar la suscripción. Puede existir una suscripción activa duplicada para el mismo cliente, servicio y caja.";
            Console.WriteLine(ex.ToString());
        }
        catch (Exception ex)
        {
            error = $"Error al guardar la suscripción: {ex.Message}";
            Console.WriteLine(ex.ToString());
        }
    }

    private async Task ValidarSuscripcion()
    {
        if (suscripcionEditando.ClienteId <= 0)
            erroresValidacion.Add("Debe seleccionar un cliente.");

        if (suscripcionEditando.ServicioPlanId <= 0)
            erroresValidacion.Add("Debe seleccionar un servicio.");

        if (suscripcionEditando.CajaDistribucionId <= 0)
            erroresValidacion.Add("Debe seleccionar una caja de distribución.");

        if (string.IsNullOrWhiteSpace(suscripcionEditando.DireccionInstalacion))
            erroresValidacion.Add("Debe cargar la dirección de instalación.");

        if (suscripcionEditando.PrecioActualSnapshot < 0)
            erroresValidacion.Add("El precio no puede ser negativo.");

        if (suscripcionEditando.EstadoActual == EstadoSuscripcionTipo.Baja && suscripcionEditando.FechaBaja is null)
            erroresValidacion.Add("Si la suscripción está en baja, debe cargar fecha de baja.");

        if (suscripcionEditando.FechaBaja is not null && suscripcionEditando.FechaBaja < suscripcionEditando.FechaAlta)
            erroresValidacion.Add("La fecha de baja no puede ser anterior a la fecha de alta.");

        var existeDuplicada = await DbContext.Suscripciones
            .AsNoTracking()
            .AnyAsync(x =>
            x.Id != suscripcionEditando.Id &&
            x.ClienteId == suscripcionEditando.ClienteId &&
            x.ServicioPlanId == suscripcionEditando.ServicioPlanId &&
            x.EstadoActual == EstadoSuscripcionTipo.Activo);

        if (existeDuplicada && suscripcionEditando.EstadoActual == EstadoSuscripcionTipo.Activo)
            erroresValidacion.Add("Ya existe una suscripción activa para ese cliente con el mismo servicio.");
    }

    private void CancelarEdicion()
    {
        editando = false;
        mensaje = null;
        error = null;
        erroresValidacion.Clear();
    }
}

<style>
    .grid-scroll {
        max-height: 520px;
        overflow-y: auto;
    }

    .grid-scroll thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #f8f9fa;
    }
</style>