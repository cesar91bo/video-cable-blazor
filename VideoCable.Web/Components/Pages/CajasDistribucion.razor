@page "/cajas-distribucion"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using VideoCable.Domain.Entities
@using VideoCable.Infrastructure.Data
@using Microsoft.JSInterop
@using VideoCable.Domain.Enums
@using System.Globalization

@inject IConfiguration Configuration
@inject IJSRuntime JSRuntime
@inject AppDbContext DbContext

<PageTitle>Cajas de distribución</PageTitle>

<div class="page-header">
    <div>
        <h1>Cajas de distribución</h1>
        <p class="text-muted mb-0">Cajas físicas/red donde se conectan los abonados.</p>
    </div>

    <button class="btn btn-primary" @onclick="NuevaCaja">
        Nueva caja
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-success mt-3">
        @mensaje
    </div>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger mt-3">
        @error
    </div>
}

@if (editando)
{
    <div class="card mt-4">
        <div class="card-header">
            @(cajaEditando.Id == 0 ? "Nueva caja" : "Editar caja")
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Código</label>
                    <input class="form-control" @bind="cajaEditando.Codigo" />
                </div>

                <div class="col-md-4">
                    <label class="form-label">Descripción</label>
                    <input class="form-control" @bind="cajaEditando.Descripcion" />
                </div>

                <div class="col-md-5">
                    <label class="form-label">Dirección / Referencia</label>
                    <input class="form-control" @bind="cajaEditando.Direccion" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Zona</label>
                    <input class="form-control" @bind="cajaEditando.Zona" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Latitud</label>
                    <input class="form-control"
                           placeholder="-26.052679"
                           @bind="latitudTexto"
                           @bind:event="oninput" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Longitud</label>
                    <input class="form-control"
                           placeholder="-59.944320"
                           @bind="longitudTexto"
                           @bind:event="oninput" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="cajaEditando.Activa" />
                        <label class="form-check-label">Activa</label>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button class="btn btn-success" @onclick="GuardarCaja">
                    Guardar
                </button>

                <button class="btn btn-outline-secondary" @onclick="CancelarEdicion">
                    Cancelar
                </button>
            </div>
        </div>
    </div>
}

@if (cajas is null)
{
    <p class="mt-4">Cargando cajas...</p>
}
else
{
    <div class="card mt-4">
        <div class="card-header">
            Cajas registradas
        </div>

        <div class="table-responsive grid-scroll">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Descripción</th>
                        <th>Dirección / Referencia</th>
                        <th>Zona</th>
                        <th>Activa</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var caja in cajas)
                    {
                        <tr>
                            <td>@caja.Codigo</td>
                            <td>@caja.Descripcion</td>
                            <td>@caja.Direccion</td>
                            <td>@caja.Zona</td>
                            <td>
                                @if (caja.Activa)
                                {
                                    <span class="badge bg-success">Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditarCaja(caja.Id)">
                                    Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Mapa de cajas</span>

        <button class="btn btn-sm btn-outline-primary" @onclick="CargarMapa">
            Actualizar mapa
        </button>
    </div>

    <div class="card-body">
        <div class="text-muted mb-2">
            Se muestran únicamente las cajas que tengan latitud y longitud cargadas.
        </div>

        <div id="mapa-cajas" style="height: 480px; width: 100%; border-radius: 0.75rem; overflow: hidden;"></div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Clientes por caja</span>

        <button class="btn btn-sm btn-outline-primary" @onclick="CargarResumenCajas">
            Actualizar resumen
        </button>
    </div>

    <div class="table-responsive grid-scroll">
        <table class="table table-striped table-hover mb-0">
            <thead>
                <tr>
                    <th>Caja</th>
                    <th>Dirección / Referencia</th>
                    <th class="text-end">Activos</th>
                    <th class="text-end">Suspendidos</th>
                    <th class="text-end">Con deuda</th>
                    <th class="text-end">Total clientes</th>
                    <th class="text-end">Total deuda</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in resumenCajas)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@item.Codigo</div>
                            <div class="text-muted small">@item.Descripcion</div>
                        </td>
                        <td>@item.Direccion</td>
                        <td class="text-end">@item.ClientesActivos</td>
                        <td class="text-end">@item.ClientesSuspendidos</td>
                        <td class="text-end">@item.ClientesConDeuda</td>
                        <td class="text-end">@item.TotalClientes</td>
                        <td class="text-end fw-bold">@item.TotalDeuda.ToString("C0")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => VerClientesCaja(item.CajaDistribucionId)">
                                Ver clientes
                            </button>
                        </td>
                    </tr>
                }

                @if (!resumenCajas.Any())
                {
                    <tr>
                        <td colspan="8" class="text-muted">
                            No hay cajas con clientes asociados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (cajaSeleccionada is not null)
{
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                Clientes asociados a @cajaSeleccionada.Codigo - @cajaSeleccionada.Descripcion
            </span>

            <button class="btn btn-sm btn-outline-secondary" @onclick="CerrarClientesCaja">
                Cerrar
            </button>
        </div>

        <div class="table-responsive grid-scroll">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Servicio</th>
                        <th>Dirección</th>
                        <th>Teléfono</th>
                        <th>Estado</th>
                        <th class="text-end">Deuda</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cliente in clientesCajaSeleccionada)
                    {
                        <tr class="@(cliente.Deuda > 0 ? "table-warning" : "")">
                            <td>
                                <div class="fw-semibold">@cliente.ClienteNombre</div>
                                <div class="text-muted small">Código @cliente.ClienteCodigo</div>
                            </td>
                            <td>@cliente.Servicio</td>
                            <td>@cliente.Direccion</td>
                            <td>@cliente.Telefono</td>
                            <td>
                                @if (cliente.Estado == EstadoSuscripcionTipo.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else if (cliente.Estado == EstadoSuscripcionTipo.Suspendido)
                                {
                                    <span class="badge bg-warning text-dark">Suspendido</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Baja</span>
                                }
                            </td>
                            <td class="text-end fw-bold">@cliente.Deuda.ToString("C0")</td>
                        </tr>
                    }

                    @if (!clientesCajaSeleccionada.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-muted">
                                No hay clientes asociados a esta caja.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<CajaDistribucion>? cajas;
    private CajaDistribucion cajaEditando = new();
    private string? latitudTexto;
    private string? longitudTexto;
    private string? error;
    private bool editando;
    private string? mensaje;
    private List<ResumenCajaItem> resumenCajas = new();
    private ResumenCajaItem? cajaSeleccionada;
    private List<ClienteCajaItem> clientesCajaSeleccionada = new();


    protected override async Task OnInitializedAsync()
    {
        await CargarCajas();
        await CargarResumenCajas();
    }

    private async Task CargarCajas()
    {
        cajas = await DbContext.CajasDistribucion
            .AsNoTracking()
            .OrderBy(x => x.Codigo)
            .ToListAsync();
    }

    private void NuevaCaja()
    {
        mensaje = null;
        error = null;
        latitudTexto = null;
        longitudTexto = null;

        cajaEditando = new CajaDistribucion
        {
            Codigo = "",
            Descripcion = "",
            Direccion = "",
            Zona = "",
            Activa = true,
            CreatedAt = DateTime.Now
        };

        editando = true;
    }

    private async Task EditarCaja(int id)
    {
        mensaje = null;

        var caja = await DbContext.CajasDistribucion
            .AsNoTracking()
            .FirstAsync(x => x.Id == id);

        cajaEditando = new CajaDistribucion
        {
            Id = caja.Id,
            Codigo = caja.Codigo,
            Descripcion = caja.Descripcion,
            Direccion = caja.Direccion,
            Zona = caja.Zona,
            Latitud = caja.Latitud,
            Longitud = caja.Longitud,
            Activa = caja.Activa,
            CreatedAt = caja.CreatedAt,
            CreatedByUserId = caja.CreatedByUserId,
            IsDeleted = caja.IsDeleted,
            RowVersion = caja.RowVersion
        };

        latitudTexto = caja.Latitud?.ToString(System.Globalization.CultureInfo.InvariantCulture);
        longitudTexto = caja.Longitud?.ToString(System.Globalization.CultureInfo.InvariantCulture);

        editando = true;
    }

    private async Task GuardarCaja()
    {
        mensaje = null;
        error = null;

        if (string.IsNullOrWhiteSpace(cajaEditando.Codigo))
        {
            error = "Debe ingresar el código de la caja.";
            return;
        }

        if (string.IsNullOrWhiteSpace(cajaEditando.Descripcion))
        {
            error = "Debe ingresar la descripción de la caja.";
            return;
        }

        if (!ValidarCoordenadas())
            return;

        try
        {
            if (cajaEditando.Id == 0)
            {
                cajaEditando.CreatedAt = DateTime.Now;

                DbContext.CajasDistribucion.Add(cajaEditando);
            }
            else
            {
                var caja = await DbContext.CajasDistribucion
                    .FirstAsync(x => x.Id == cajaEditando.Id);

                caja.Codigo = cajaEditando.Codigo?.Trim();
                caja.Descripcion = cajaEditando.Descripcion.Trim();
                caja.Direccion = cajaEditando.Direccion?.Trim();
                caja.Zona = cajaEditando.Zona?.Trim();

                caja.Latitud = cajaEditando.Latitud;
                caja.Longitud = cajaEditando.Longitud;

                caja.Activa = cajaEditando.Activa;
                caja.UpdatedAt = DateTime.Now;
            }

            await DbContext.SaveChangesAsync();

            editando = false;
            mensaje = "Caja guardada correctamente.";

            await CargarCajas();
            await CargarResumenCajas();
            await CargarMapa();
        }
        catch (Exception ex)
        {
            error = $"Error al guardar la caja: {ex.Message}";
            Console.WriteLine(ex.ToString());
        }
    }

    private bool ValidarCoordenadas()
    {
        cajaEditando.Latitud = null;
        cajaEditando.Longitud = null;

        if (!string.IsNullOrWhiteSpace(latitudTexto))
        {
            var textoLatitud = latitudTexto.Trim().Replace(",", ".");

            if (!decimal.TryParse(
                    textoLatitud,
                    NumberStyles.Number,
                    CultureInfo.InvariantCulture,
                    out var latitud))
            {
                error = "La latitud no tiene un formato válido. Ejemplo: -26.052679";
                return false;
            }

            cajaEditando.Latitud = Math.Round(latitud, 6);
        }

        if (!string.IsNullOrWhiteSpace(longitudTexto))
        {
            var textoLongitud = longitudTexto.Trim().Replace(",", ".");

            if (!decimal.TryParse(
                    textoLongitud,
                    NumberStyles.Number,
                    CultureInfo.InvariantCulture,
                    out var longitud))
            {
                error = "La longitud no tiene un formato válido. Ejemplo: -59.944320";
                return false;
            }

            cajaEditando.Longitud = Math.Round(longitud, 6);
        }

        return true;
    }

    private void CancelarEdicion()
    {
        editando = false;
        mensaje = null;
    }

    private async Task CargarMapa()
    {
        if (cajas is null)
            return;

        var apiKey = Configuration["GoogleMaps:ApiKey"];

        var cajasMapa = cajas
            .Where(x => x.Activa && x.Latitud.HasValue && x.Longitud.HasValue)
            .Select(x => new CajaMapaDto
            {
                Codigo = x.Codigo,
                Descripcion = x.Descripcion,
                Direccion = x.Direccion,
                Latitud = x.Latitud!.Value,
                Longitud = x.Longitud!.Value
            })
            .ToList();

        await JSRuntime.InvokeVoidAsync(
            "videoCableMaps.initCajasMap",
            "mapa-cajas",
            apiKey,
            cajasMapa);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CargarMapa();
        }
    }

    private async Task CargarResumenCajas()
    {
        var facturasConSaldo = await DbContext.Facturas
            .AsNoTracking()
            .Include(x => x.PagoAplicaciones)
            .Where(x =>
                x.EstadoCobranza == EstadoCobranzaFactura.Pendiente ||
                x.EstadoCobranza == EstadoCobranzaFactura.Parcial)
            .Select(x => new
            {
                x.SuscripcionId,
                Saldo = x.Total - x.PagoAplicaciones.Sum(p => p.MontoAplicado)
            })
            .ToListAsync();

        var deudaPorSuscripcion = facturasConSaldo
            .Where(x => x.Saldo > 0)
            .GroupBy(x => x.SuscripcionId)
            .ToDictionary(
                g => g.Key,
                g => g.Sum(x => x.Saldo));

        var suscripciones = await DbContext.Suscripciones
            .AsNoTracking()
            .Include(x => x.Cliente)
            .Include(x => x.ServicioPlan)
            .Include(x => x.CajaDistribucion)
            .Where(x => !x.IsDeleted)
            .ToListAsync();

        resumenCajas = suscripciones
            .GroupBy(x => x.CajaDistribucionId)
            .Select(g =>
            {
                var caja = g.First().CajaDistribucion;

                var totalClientes = g
                    .Select(x => x.ClienteId)
                    .Distinct()
                    .Count();

                var clientesActivos = g
                    .Where(x => x.EstadoActual == EstadoSuscripcionTipo.Activo)
                    .Select(x => x.ClienteId)
                    .Distinct()
                    .Count();

                var clientesSuspendidos = g
                    .Where(x => x.EstadoActual == EstadoSuscripcionTipo.Suspendido)
                    .Select(x => x.ClienteId)
                    .Distinct()
                    .Count();

                var clientesConDeuda = g
                    .Where(x =>
                        x.Id > 0 &&
                        deudaPorSuscripcion.ContainsKey(x.Id) &&
                        deudaPorSuscripcion[x.Id] > 0)
                    .Select(x => x.ClienteId)
                    .Distinct()
                    .Count();

                var totalDeuda = g.Sum(x =>
                    deudaPorSuscripcion.TryGetValue(x.Id, out var deuda)
                        ? deuda
                        : 0);

                return new ResumenCajaItem
                {
                    CajaDistribucionId = caja.Id,
                    Codigo = caja.Codigo,
                    Descripcion = caja.Descripcion,
                    Direccion = caja.Direccion,
                    ClientesActivos = clientesActivos,
                    ClientesSuspendidos = clientesSuspendidos,
                    ClientesConDeuda = clientesConDeuda,
                    TotalClientes = totalClientes,
                    TotalDeuda = totalDeuda
                };
            })
            .OrderBy(x => x.Codigo)
            .ToList();
    }

    private async Task VerClientesCaja(int cajaDistribucionId)
    {
        cajaSeleccionada = resumenCajas.FirstOrDefault(x => x.CajaDistribucionId == cajaDistribucionId);
        clientesCajaSeleccionada = new();

        var facturasConSaldo = await DbContext.Facturas
            .AsNoTracking()
            .Include(x => x.PagoAplicaciones)
            .Where(x =>
                x.EstadoCobranza == EstadoCobranzaFactura.Pendiente ||
                x.EstadoCobranza == EstadoCobranzaFactura.Parcial)
            .Select(x => new
            {
                x.SuscripcionId,
                Saldo = x.Total - x.PagoAplicaciones.Sum(p => p.MontoAplicado)
            })
            .ToListAsync();

        var deudaPorSuscripcion = facturasConSaldo
            .Where(x => x.Saldo > 0)
            .GroupBy(x => x.SuscripcionId)
            .ToDictionary(
                g => g.Key,
                g => g.Sum(x => x.Saldo));

        var suscripciones = await DbContext.Suscripciones
            .AsNoTracking()
            .Include(x => x.Cliente)
            .Include(x => x.ServicioPlan)
            .Where(x =>
                !x.IsDeleted &&
                x.CajaDistribucionId == cajaDistribucionId)
            .OrderBy(x => x.Cliente.Nombre)
            .ToListAsync();

        clientesCajaSeleccionada = suscripciones
            .Select(x => new ClienteCajaItem
            {
                ClienteId = x.ClienteId,
                ClienteCodigo = x.Cliente.Codigo,
                ClienteNombre = x.Cliente.Nombre,
                Direccion = x.Cliente.Direccion,
                Telefono = x.Cliente.Telefono,
                Servicio = x.ServicioPlan.Descripcion,
                Estado = x.EstadoActual,
                Deuda = deudaPorSuscripcion.TryGetValue(x.Id, out var deuda)
                    ? deuda
                    : 0
            })
            .OrderByDescending(x => x.Deuda)
            .ThenBy(x => x.ClienteNombre)
            .ToList();
    }

    private void CerrarClientesCaja()
    {
        cajaSeleccionada = null;
        clientesCajaSeleccionada = new();
    }

    private class CajaMapaDto
    {
        public string? Codigo { get; set; }
        public string Descripcion { get; set; } = string.Empty;
        public string? Direccion { get; set; }
        public decimal Latitud { get; set; }
        public decimal Longitud { get; set; }
    }

    private class ResumenCajaItem
    {
        public int CajaDistribucionId { get; set; }
        public string? Codigo { get; set; }
        public string Descripcion { get; set; } = string.Empty;
        public string? Direccion { get; set; }
        public int ClientesActivos { get; set; }
        public int ClientesSuspendidos { get; set; }
        public int ClientesConDeuda { get; set; }
        public int TotalClientes { get; set; }
        public decimal TotalDeuda { get; set; }
    }

    private class ClienteCajaItem
    {
        public int ClienteId { get; set; }
        public int ClienteCodigo { get; set; }
        public string ClienteNombre { get; set; } = string.Empty;
        public string? Direccion { get; set; }
        public string? Telefono { get; set; }
        public string Servicio { get; set; } = string.Empty;
        public EstadoSuscripcionTipo Estado { get; set; }
        public decimal Deuda { get; set; }
    }
}

<style>
    .grid-scroll {
        max-height: 520px;
        overflow-y: auto;
    }

    .grid-scroll thead th {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #f8f9fa;
    }
</style>