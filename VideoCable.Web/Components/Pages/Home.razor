@page "/"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using VideoCable.Domain.Entities
@using VideoCable.Domain.Enums
@using VideoCable.Infrastructure.Data
@using CajaDiariaEntity = VideoCable.Domain.Entities.CajaDiaria
@using System.Globalization

@inject AppDbContext DbContext

<PageTitle>Inicio</PageTitle>

<div class="page-header">
    <div>
        <h1>Panel de control</h1>
        <p class="text-muted mb-0">Resumen operativo del sistema.</p>
    </div>

    <button class="btn btn-outline-primary" @onclick="CargarDashboard">
        Actualizar
    </button>
</div>

@if (cargando)
{
    <p class="mt-4">Cargando información...</p>
}
else
{
    <div class="row mt-4 g-3">
        <div class="col-md-4">
            <div class="dashboard-card">
                <div class="dashboard-label">Caja diaria</div>
                <div class="dashboard-value">
                    @if (cajaAbierta is not null)
                    {
                        <span class="text-success">Abierta</span>
                    }
                    else
                    {
                        <span class="text-secondary">Cerrada</span>
                    }
                </div>
                <div class="dashboard-subtitle">
                    @if (cajaAbierta is not null)
                    {
                        <span>Desde @cajaAbierta.FechaApertura.ToString("HH:mm")</span>
                    }
                    else
                    {
                        <span>Sin caja abierta</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dashboard-card">
                <div class="dashboard-label">Cobrado hoy</div>
                <div class="dashboard-value">@cobradoHoy.ToString("C0")</div>
                <div class="dashboard-subtitle">@cantidadPagosHoy pagos registrados</div>
            </div>
        </div>

        @* <div class="col-md-3">
            <div class="dashboard-card">
                <div class="dashboard-label">Facturas pendientes</div>
                <div class="dashboard-value">@cantidadFacturasPendientes</div>
                <div class="dashboard-subtitle">Deuda: @deudaPendiente.ToString("C0")</div>
            </div>
        </div> *@

        <div class="col-md-4">
            <div class="dashboard-card">
                <div class="dashboard-label">Facturado mes actual</div>
                <div class="dashboard-value">@facturadoMes.ToString("C0")</div>
                <div class="dashboard-subtitle">@cantidadFacturasMes facturas generadas</div>
            </div>
        </div>
    </div>

    <div class="row mt-4 g-3">
        <div class="col-md-12">
            <div class="card dashboard-clientes-card">
                <div class="card-header">
                    Estado general de clientes
                </div>

                <div class="card-body">
                    <div class="clientes-dashboard-layout">
                        <div class="clientes-pie-container">
                            <div class="clientes-pie" style="@graficoClientesStyle"></div>

                            <div class="clientes-pie-total">
                                <strong>@totalClientesClasificados</strong>
                                <span>clientes</span>
                            </div>
                        </div>

                        <div class="clientes-resumen">
                            <div class="clientes-resumen-item normal">
                                <div class="clientes-resumen-numero">@clientesNormal</div>
                                <div>
                                    <div class="fw-semibold">Normal</div>
                                    <div class="text-muted small">Activos sin deuda</div>
                                </div>
                            </div>

                            <div class="clientes-resumen-item precaucion">
                                <div class="clientes-resumen-numero">@clientesPrecaucion</div>
                                <div>
                                    <div class="fw-semibold">Precaución</div>
                                    <div class="text-muted small">Activos con 1 mes adeudado</div>
                                </div>
                            </div>

                            <div class="clientes-resumen-item deudores">
                                <div class="clientes-resumen-numero">@clientesDeudores</div>
                                <div>
                                    <div class="fw-semibold">Deudores</div>
                                    <div class="text-muted small">Activos con 2 o más meses adeudados</div>
                                </div>
                            </div>

                            @if (clientesOtros > 0)
                            {
                                <div class="clientes-resumen-item otros">
                                    <div class="clientes-resumen-numero">@clientesOtros</div>
                                    <div>
                                        <div class="fw-semibold">Otros</div>
                                        <div class="text-muted small">Suspendidos, baja o sin activa</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4 g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    Estado de facturación del mes
                </div>

                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Pagadas</span>
                        <strong>@facturasPagadasMes de @cantidadFacturasMes</strong>
                    </div>

                    <div class="progress mb-3" style="height: 22px;">
                        <div class="progress-bar bg-success"
                             style="width:@porcentajePagadasMes%">
                            @porcentajePagadasMes.ToString("0")%
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Pendientes / parciales</span>
                        <strong>@facturasPendientesMes</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    Caja de hoy
                </div>

                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="text-muted">Ingresos</div>
                            <h4>@ingresosCajaHoy.ToString("C0")</h4>
                        </div>

                        <div class="col-md-4">
                            <div class="text-muted">Egresos</div>
                            <h4>@egresosCajaHoy.ToString("C0")</h4>
                        </div>

                        <div class="col-md-4">
                            <div class="text-muted">Saldo</div>
                            <h4>@saldoCajaHoy.ToString("C0")</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4 g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    Últimos cobros
                </div>

                <div class="table-responsive grid-scroll-small">
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th class="text-end">Importe</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pago in ultimosPagos)
                            {
                                <tr>
                                    <td>@pago.Fecha.ToString("dd/MM HH:mm")</td>
                                    <td>@pago.ClienteNombre</td>
                                    <td class="text-end">@pago.Total.ToString("C0")</td>
                                </tr>
                            }

                            @if (!ultimosPagos.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-muted">Sin cobros registrados.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    Movimientos de caja de hoy
                </div>

                <div class="table-responsive grid-scroll-small">
                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Hora</th>
                                <th>Tipo</th>
                                <th>Concepto</th>
                                <th class="text-end">Monto</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mov in movimientosHoy)
                            {
                                <tr>
                                    <td>@mov.Fecha.ToString("HH:mm")</td>
                                    <td>@mov.Tipo</td>
                                    <td>@mov.Concepto</td>
                                    <td class="text-end">@mov.Monto.ToString("C0")</td>
                                </tr>
                            }

                            @if (!movimientosHoy.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-muted">Sin movimientos registrados hoy.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool cargando = true;

    private CajaDiariaEntity? cajaAbierta;

    private decimal cobradoHoy;
    private int cantidadPagosHoy;

    private List<PagoResumen> ultimosPagos = new();
    private List<MovimientoCaja> movimientosHoy = new();
    private int cantidadFacturasPendientes;
    private decimal deudaPendiente;
    private int clientesNormal;
    private int clientesPrecaucion;
    private int clientesDeudores;
    private int clientesOtros;
    private int totalClientesClasificados;
    private string graficoClientesStyle = "";

    private decimal facturadoMes;
    private int cantidadFacturasMes;
    private int facturasPagadasMes;
    private int facturasPendientesMes;
    private decimal porcentajePagadasMes;

    private decimal ingresosCajaHoy;
    private decimal egresosCajaHoy;
    private decimal saldoCajaHoy;

    

    protected override async Task OnInitializedAsync()
    {
        await CargarDashboard();
    }

    private async Task CargarDashboard()
    {
        cargando = true;

        var hoy = DateTime.Today;
        var manana = hoy.AddDays(1);

        var mesActual = DateTime.Today.Month;
        var anioActual = DateTime.Today.Year;

        cajaAbierta = await DbContext.CajasDiarias
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.Estado == EstadoCajaDiaria.Abierta);

        var pagosHoy = await DbContext.Pagos
            .AsNoTracking()
            .Where(x =>
                x.Estado == EstadoPago.Registrado &&
                x.Fecha >= hoy &&
                x.Fecha < manana)
            .ToListAsync();

        cobradoHoy = pagosHoy.Sum(x => x.Total);
        cantidadPagosHoy = pagosHoy.Count;

        var facturasConDeuda = await DbContext.Facturas
            .AsNoTracking()
            .Include(x => x.PagoAplicaciones)
            .Where(x =>
                x.EstadoCobranza == EstadoCobranzaFactura.Pendiente ||
                x.EstadoCobranza == EstadoCobranzaFactura.Parcial)
            .ToListAsync();

        cantidadFacturasPendientes = facturasConDeuda.Count;
        deudaPendiente = facturasConDeuda
            .Sum(x => x.Total - x.PagoAplicaciones.Sum(p => p.MontoAplicado));

        var deudaPorCliente = facturasConDeuda
    .Select(x => new
    {
        x.ClienteId,
        x.PeriodoAnio,
        x.PeriodoMes,
        Saldo = x.Total - x.PagoAplicaciones.Sum(p => p.MontoAplicado)
    })
    .Where(x => x.Saldo > 0)
    .GroupBy(x => x.ClienteId)
    .ToDictionary(
        g => g.Key,
        g => new
        {
            TotalDeuda = g.Sum(x => x.Saldo),
            MesesAdeudados = g
                .Select(x => new { x.PeriodoAnio, x.PeriodoMes })
                .Distinct()
                .Count()
        });

        var suscripcionesClientes = await DbContext.Suscripciones
            .AsNoTracking()
            .Include(x => x.Cliente)
            .Where(x => !x.IsDeleted && x.Cliente.Activo)
            .ToListAsync();

        var clientesClasificados = suscripcionesClientes
            .GroupBy(x => x.ClienteId)
            .Select(g => new
            {
                ClienteId = g.Key,
                TieneActiva = g.Any(x => x.EstadoActual == EstadoSuscripcionTipo.Activo),
                TieneSuspendida = g.Any(x => x.EstadoActual == EstadoSuscripcionTipo.Suspendido),
                TieneBaja = g.Any(x => x.EstadoActual == EstadoSuscripcionTipo.Baja)
            })
            .ToList();

        clientesNormal = 0;
        clientesPrecaucion = 0;
        clientesDeudores = 0;
        clientesOtros = 0;

        foreach (var cliente in clientesClasificados)
        {
            if (!cliente.TieneActiva)
            {
                clientesOtros++;
                continue;
            }

            if (!deudaPorCliente.TryGetValue(cliente.ClienteId, out var deudaCliente))
            {
                clientesNormal++;
                continue;
            }

            if (deudaCliente.MesesAdeudados >= 2)
            {
                clientesDeudores++;
            }
            else if (deudaCliente.MesesAdeudados == 1)
            {
                clientesPrecaucion++;
            }
            else
            {
                clientesNormal++;
            }
        }

        totalClientesClasificados = clientesNormal + clientesPrecaucion + clientesDeudores + clientesOtros;

        ActualizarGraficoClientes();

        var facturasMes = await DbContext.Facturas
            .AsNoTracking()
            .Where(x => x.PeriodoAnio == anioActual && x.PeriodoMes == mesActual)
            .ToListAsync();

        cantidadFacturasMes = facturasMes.Count;
        facturadoMes = facturasMes.Sum(x => x.Total);
        facturasPagadasMes = facturasMes.Count(x => x.EstadoCobranza == EstadoCobranzaFactura.Pagada);
        facturasPendientesMes = facturasMes.Count(x =>
            x.EstadoCobranza == EstadoCobranzaFactura.Pendiente ||
            x.EstadoCobranza == EstadoCobranzaFactura.Parcial);

        porcentajePagadasMes = cantidadFacturasMes == 0
            ? 0
            : (decimal)facturasPagadasMes / cantidadFacturasMes * 100;

        movimientosHoy = await DbContext.MovimientosCaja
            .AsNoTracking()
            .Where(x => x.Fecha >= hoy && x.Fecha < manana)
            .OrderByDescending(x => x.Fecha)
            .ToListAsync();

        ingresosCajaHoy = movimientosHoy
            .Where(x =>
                !x.Anulado &&
                (x.Tipo == TipoMovimientoCaja.Ingreso ||
                 x.Tipo == TipoMovimientoCaja.Cobro ||
                 x.Tipo == TipoMovimientoCaja.Ajuste))
            .Sum(x => x.Monto);

        egresosCajaHoy = movimientosHoy
            .Where(x => !x.Anulado && x.Tipo == TipoMovimientoCaja.Egreso)
            .Sum(x => x.Monto);

        saldoCajaHoy = ingresosCajaHoy - egresosCajaHoy;

        ultimosPagos = await DbContext.Pagos
            .AsNoTracking()
            .Include(x => x.Cliente)
            .Where(x => x.Estado == EstadoPago.Registrado)
            .OrderByDescending(x => x.Fecha)
            .Take(10)
            .Select(x => new PagoResumen
            {
                Fecha = x.Fecha,
                ClienteNombre = x.Cliente.Nombre,
                Total = x.Total
            })
            .ToListAsync();

        cargando = false;
    }

    private void ActualizarGraficoClientes()
    {
        if (totalClientesClasificados <= 0)
        {
            graficoClientesStyle = "background: #e5e7eb;";
            return;
        }

        decimal normalFin = clientesNormal * 360m / totalClientesClasificados;
        decimal precaucionFin = normalFin + clientesPrecaucion * 360m / totalClientesClasificados;
        decimal deudoresFin = precaucionFin + clientesDeudores * 360m / totalClientesClasificados;

        string n1 = normalFin.ToString("0.##", CultureInfo.InvariantCulture);
        string n2 = precaucionFin.ToString("0.##", CultureInfo.InvariantCulture);
        string n3 = deudoresFin.ToString("0.##", CultureInfo.InvariantCulture);

        graficoClientesStyle =
            $"background: conic-gradient(" +
            $"#198754 0deg {n1}deg, " +
            $"#ffc107 {n1}deg {n2}deg, " +
            $"#dc3545 {n2}deg {n3}deg, " +
            $"#6c757d {n3}deg 360deg);";
    }

    private class PagoResumen
    {
        public DateTime Fecha { get; set; }
        public string ClienteNombre { get; set; } = string.Empty;
        public decimal Total { get; set; }
    }
}

<style>
    .dashboard-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.85rem;
        padding: 1.25rem;
        min-height: 130px;
        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.08);
    }

    .dashboard-label {
        color: #6b7280;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04rem;
    }

    .dashboard-value {
        font-size: 1.85rem;
        font-weight: 700;
        margin-top: 0.45rem;
    }

    .dashboard-subtitle {
        color: #6b7280;
        font-size: 0.9rem;
        margin-top: 0.25rem;
    }

    .grid-scroll-small {
        max-height: 300px;
        overflow-y: auto;
    }

        .grid-scroll-small thead th {
            position: sticky;
            top: 0;
            z-index: 2;
            background: #f8f9fa;
        }

    .dashboard-clientes-card {
        min-height: 260px;
    }

    .clientes-dashboard-layout {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .clientes-pie-container {
        position: relative;
        width: 190px;
        height: 190px;
        flex: 0 0 auto;
    }

    .clientes-pie {
        width: 190px;
        height: 190px;
        border-radius: 50%;
        box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.08);
    }

        .clientes-pie::after {
            content: "";
            position: absolute;
            inset: 42px;
            background: #ffffff;
            border-radius: 50%;
            box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.05);
        }

    .clientes-pie-total {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        pointer-events: none;
        z-index: 1;
    }

        .clientes-pie-total strong {
            font-size: 2.25rem;
            line-height: 1;
            color: #111827;
        }

        .clientes-pie-total span {
            font-size: 0.9rem;
            color: #6b7280;
            margin-top: 0.15rem;
        }

    .clientes-resumen {
        display: grid;
        grid-template-columns: repeat(2, minmax(220px, 1fr));
        gap: 1rem;
        min-width: 520px;
    }

    .clientes-resumen-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-left-width: 6px;
        border-radius: 0.85rem;
        padding: 1rem;
    }

        .clientes-resumen-item.normal {
            border-left-color: #198754;
        }

        .clientes-resumen-item.precaucion {
            border-left-color: #ffc107;
        }

        .clientes-resumen-item.deudores {
            border-left-color: #dc3545;
        }

        .clientes-resumen-item.otros {
            border-left-color: #6c757d;
        }

    .clientes-resumen-numero {
        min-width: 54px;
        height: 54px;
        border-radius: 999px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        font-weight: 800;
        color: #111827;
    }

    @@media (max-width: 992px) {
        .clientes-dashboard-layout {
            gap: 1.5rem;
        }

        .clientes-resumen {
            min-width: 100%;
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .clientes-pie-container {
            width: 155px;
            height: 155px;
        }

        .clientes-pie {
            width: 155px;
            height: 155px;
        }

            .clientes-pie::after {
                inset: 34px;
            }

        .clientes-pie-total strong {
            font-size: 1.8rem;
        }

        .clientes-pie-total span {
            font-size: 0.8rem;
        }
    }
</style>