        color: #6b7280;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04rem;
    }

    .dashboard-value {
        font-size: 1.75rem;
        font-weight: 700;
        margin-top: 0.35rem;
    }

    .dashboard-subtitle {
        color: #6b7280;
        font-size: 0.9rem;
        margin-top: 0.25rem;
    }

    .deuda-card {
        border-color: #f59e0b;
    }

    @@media print {
        body {
            background: #ffffff !important;
        }

        .no-print,
        .sidebar,
        .top-row,
        .page-header button {
            display: none !important;
        }

        .content {
            padding: 0 !important;
        }

        .estado-cuenta-print {
            border: none !important;
            box-shadow: none !important;
            margin-top: 0 !important;
        }

        .dashboard-card {
            box-shadow: none !important;
        }

        .comprobante-header {
            grid-template-columns: 160px 1fr 220px;
        }

        .empresa-logo img {
            max-width: 150px;
        }
    }

    .comprobante-header {
        display: grid;
        grid-template-columns: 180px 1fr 260px;
        gap: 1.25rem;
        align-items: center;
    }

    .empresa-logo img {
        max-width: 170px;
        max-height: 100px;
        object-fit: contain;
    }

    .empresa-datos {
        font-size: 0.95rem;
        color: #374151;
    }

    .empresa-nombre {
        font-weight: 800;
        font-size: 1.1rem;
        color: #111827;
        margin-bottom: 0.25rem;
    }

    .comprobante-titulo {
        text-align: right;
    }
</style>